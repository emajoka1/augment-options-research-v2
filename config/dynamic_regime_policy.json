{
  "version": "1.0.0",
  "name": "steady_compounder_dynamic_regime_policy",
  "regime_tiers": [
    {"tier": 1, "label": "LOW_VOL", "vix_min": null, "vix_max": 15.0},
    {"tier": 2, "label": "NORMAL_VOL", "vix_min": 15.01, "vix_max": 19.99},
    {"tier": 3, "label": "ELEVATED_VOL", "vix_min": 20.0, "vix_max": 27.99},
    {"tier": 4, "label": "HIGH_VOL", "vix_min": 28.0, "vix_max": 35.99},
    {"tier": 5, "label": "CRISIS_VOL", "vix_min": 36.0, "vix_max": null}
  ],
  "persistence_rule": {
    "confirm_after_consecutive_readings": 3
  },
  "dynamic_thresholds": {
    "structural_quality_min": {
      "tier_1": 0.70,
      "tier_2": 0.65,
      "tier_3": 0.52,
      "tier_4": 0.45,
      "tier_5": 0.40,
      "hard_floor": 0.40
    },
    "mc_gate": {
      "ev_seed_p5_min_r": {"tier_1": 0.05, "tier_2": 0.03, "tier_3": -0.05, "tier_4": -0.10, "tier_5": -0.15},
      "pl_p5_min_r": {"tier_1": -0.40, "tier_2": -0.50, "tier_3": -0.60, "tier_4": -0.70, "tier_5": -0.80},
      "cvar95_min_r": {"tier_1": -0.85, "tier_2": -0.90, "tier_3": -0.95, "tier_4": -1.00, "tier_5": -1.00},
      "stress_delta_ev_min_r": {"tier_1": -0.03, "tier_2": -0.05, "tier_3": -0.15, "tier_4": -0.20, "tier_5": -0.25}
    },
    "risk_per_trade_pct": {
      "tier_1": [0.75, 1.00],
      "tier_2": [0.75, 1.00],
      "tier_3": [1.00, 1.25],
      "tier_4": [0.75, 1.00],
      "tier_5": [0.50, 0.75]
    }
  },
  "static_filters": {
    "require_clean_structural_r": true,
    "require_1r_invalidation": true,
    "explainable_required": true,
    "max_trades_day": 3,
    "max_trades_week": 6,
    "daily_loss_cap_r": -2.5,
    "max_correlated_exposure_pct": 70,
    "min_oi": 1000,
    "min_volume": 100,
    "max_single_leg_spread_pct": 10,
    "max_multi_leg_spread_pct": 5,
    "max_spread_bps": 25,
    "min_debit": 0.05,
    "min_credit": 0.05
  },
  "override": {
    "allow_manual_override": true,
    "allow_only_loosen_thresholds": true,
    "reject_if_override_tighter_than_vix_tier": true,
    "required_fields": ["REGIME_OVERRIDE", "REGIME_OVERRIDE_REASON", "REGIME_OVERRIDE_EXPIRY"]
  },
  "required_logging": {
    "regime_header": true,
    "regime_transition_event": true,
    "near_miss_on_watch": true,
    "weekly_summary_schedule": "Sunday 18:00 UTC"
  }
}
