{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KnowledgeItem",
  "type": "object",
  "required": [
    "item_id",
    "title",
    "claim",
    "evidence",
    "confidence",
    "last_verified_date",
    "expiry",
    "status"
  ],
  "properties": {
    "item_id": {"type": "string"},
    "title": {"type": "string"},
    "claim": {"type": "string"},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "source_type", "excerpt"],
        "properties": {
          "source_id": {"type": "string"},
          "source_type": {"type": "string"},
          "excerpt": {"type": "string"}
        }
      }
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "last_verified_date": {"type": "string", "format": "date"},
    "expiry": {"type": "string", "format": "date"},
    "status": {"type": "string", "enum": ["VERIFIED", "UNVERIFIED", "REJECTED"]},
    "tags": {"type": "array", "items": {"type": "string"}}
  }
}
